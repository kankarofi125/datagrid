# =============================================================================
# DataGrid environment template
# Copy to .env and fill in real values. Never commit .env.
# =============================================================================

# --- Neon Postgres ---
# Pooled (app runtime) — host includes -pooler
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
# Direct (migrations / prisma db push) — host WITHOUT -pooler
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require"

# --- App ---
SESSION_SECRET="replace-with-32+-char-secret"
PAYMENT_MODE="simulate"
OTP_MODE="simulate"
OTP_DEV_CODE="1234"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_WHATSAPP="2348000000000"
NEXT_PUBLIC_APP_NAME="DataGrid"
NEXT_PUBLIC_ENABLE_SW=

# --- Vercel Cron (Authorization: Bearer <CRON_SECRET>) ---
CRON_SECRET="replace-with-long-random-cron-secret"

# --- Upstash Redis (cache + SSE/WS fan-out) ---
UPSTASH_REDIS_REST_URL="https://YOUR-DB.upstash.io"
UPSTASH_REDIS_REST_TOKEN="YOUR_TOKEN"

# --- Realtime WebSocket gateway (Fly.io / Railway) ---
# Leave empty until the service is deployed; app falls back to SSE.
# NEXT_PUBLIC_REALTIME_WS_URL="wss://datagrid-realtime-ws.fly.dev"
# REALTIME_WS_INTERNAL_URL="https://datagrid-realtime-ws.fly.dev"
NEXT_PUBLIC_REALTIME_WS_URL=
REALTIME_WS_INTERNAL_URL=
REALTIME_WS_SECRET="replace-with-shared-ws-secret"

# --- Payments (empty = simulate) ---
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
MONNIFY_API_KEY=
MONNIFY_SECRET_KEY=
MONNIFY_CONTRACT_CODE=
FLUTTERWAVE_SECRET_KEY=

# --- Messaging ---
TERMII_API_KEY=

# --- VTU providers (empty = simulator) ---
VTPASS_API_KEY=
VTPASS_SECRET_KEY=
VTPASS_PUBLIC_KEY=
CLUBKONNECT_USER_ID=
CLUBKONNECT_API_KEY=
