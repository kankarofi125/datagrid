# Neon / Postgres
# Pooled (app runtime) — includes -pooler in host
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
# Direct (migrations) — same host without -pooler
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require"

SESSION_SECRET="replace-with-32+-char-secret"
PAYMENT_MODE="simulate"
OTP_MODE="simulate"
OTP_DEV_CODE="1234"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_WHATSAPP="2348000000000"
NEXT_PUBLIC_APP_NAME="DataGrid"
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
MONNIFY_API_KEY=
MONNIFY_SECRET_KEY=
MONNIFY_CONTRACT_CODE=
TERMII_API_KEY=
# Vercel Cron auth (Authorization: Bearer <secret>)
CRON_SECRET="replace-with-long-random-cron-secret"

# Dedicated WebSocket gateway (Fly.io / Railway) — optional
# Browser connects here when set; otherwise SSE on Vercel is used
NEXT_PUBLIC_REALTIME_WS_URL=
# Next.js server POSTs publish fan-out here (https://..., not wss)
REALTIME_WS_INTERNAL_URL=
REALTIME_WS_SECRET=

FLUTTERWAVE_SECRET_KEY=
VTPASS_API_KEY=
VTPASS_SECRET_KEY=
VTPASS_PUBLIC_KEY=
CLUBKONNECT_USER_ID=
CLUBKONNECT_API_KEY=
NEXT_PUBLIC_ENABLE_SW=

# Upstash Redis — cache + SSE realtime (never commit real tokens)
UPSTASH_REDIS_REST_URL="https://YOUR-DB.upstash.io"
UPSTASH_REDIS_REST_TOKEN="YOUR_TOKEN"
